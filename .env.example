# Copia este archivo a .env y ajusta los valores.
# NUNCA subas tu .env real al repositorio (ya está en .gitignore).

PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=rescuegis
PGUSER=postgres
PGPASSWORD=cambia_esto_por_una_contraseña_segura

# Carpeta donde se guardan las descargas completas de Overpass (no se sube al repo).
# Si no la defines, download_overpass.py usa ./data por defecto.
# RESCUEGIS_DATA_DIR=./data
